# BloodHound CE API Configuration
# ================================

# Base URL of your BloodHound CE instance (no trailing slash)
BH_BASE_URL=https://your-bloodhound-instance:8080

# API Token ID (public, like a username)
BH_TOKEN_ID=your-token-id-here

# API Token Key (secret, like a password)
BH_TOKEN_KEY=your-token-key-here

# Comma-separated list of domains to generate reports for.
# Use the FQDN as it appears in BloodHound (e.g. CORP.LOCAL)
BH_DOMAINS=YOURDOMAIN.COM

# Directory to write HTML reports into (relative or absolute)
BH_REPORT_DIR=./reports

# Minimum group member count to flag as "large" for admin rights check
BH_LARGE_GROUP_THRESHOLD=300
